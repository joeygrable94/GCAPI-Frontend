{
  "name": "app",
  "type": "module",
  "proxy": "http://localhost:8888",
  "scripts": {
    "generate-client": "openapi --input http://0.0.0.0:8888/api/docs/openapi.json --output ./src/backend --useOptions --useUnionTypes --indent 2 --client axios",
    "format": "prettier --config .prettierrc 'src/**/*.ts' --write",
    "dev": "vite",
    "build": "vite build",
    "start": "vite serve --host"
  },
  "devDependencies": {
    "@types/auth0-js": "^9.21.5",
    "@types/crypto-js": "^4.2.1",
    "@types/node": "^20.11.4",
    "openapi-typescript-codegen": "^0.26.0",
    "prettier": "^3.2.2",
    "prettier-plugin-organize-imports": "^3.2.4",
    "sass": "^1.69.7",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vite-plugin-solid": "^2.8.0",
    "vite-tsconfig-paths": "^4.3.0"
  },
  "dependencies": {
    "@solidjs/meta": "^0.29.3",
    "@solidjs/router": "^0.10.9",
    "@tanstack/solid-form": "^0.13.3",
    "@tanstack/solid-query": "^5.17.15",
    "@tanstack/solid-query-devtools": "^5.17.15",
    "@tanstack/solid-table": "^8.11.6",
    "@tanstack/zod-form-adapter": "^0.13.3",
    "auth0-js": "^9.24.1",
    "axios": "^1.6.5",
    "crypto-js": "^4.2.0",
    "localstorage-slim": "^2.7.0",
    "solid-bootstrap": "^1.0.19",
    "solid-heroicons": "^3.2.4",
    "solid-js": "^1.8.11",
    "solid-toast": "^0.5.0",
    "zod": "^3.22.4"
  },
  "engines": {
    "node": ">=18"
  }
}
